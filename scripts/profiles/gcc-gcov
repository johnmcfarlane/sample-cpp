[settings]
arch=x86_64
build_type=Debug
compiler=gcc
compiler.cppstd=26
compiler.libcxx=libstdc++
compiler.version=16
os=Linux

[buildenv]
CXX=g++

[conf]
&:tools.build:cxxflags=["-coverage"]
&:tools.cmake.cmaketoolchain:extra_variables={"CMAKE_BUILD_TYPE": "Debug", "CMAKE_CXX_STDLIB_MODULES_JSON": "/usr/local/lib64/libstdc++.modules.json"}

[tool_requires]
catch2/*:ninja/[~1]
fmt/*:cmake/[~4.4]
fmt/*:ninja/[~1]
