[settings]
arch=x86_64
build_type=Release
compiler=gcc
compiler.cppstd=26
compiler.libcxx=libstdc++
compiler.version=16
os=Linux

[buildenv]
CXX=g++

[conf]
!&:tools.build:cxxflags=["-fcontract-evaluation-semantic=ignore", "-fcontracts"]
&:tools.build:cxxflags=["-fcontract-evaluation-semantic=ignore", "-fcontracts"]
&:tools.cmake.cmaketoolchain:extra_variables={"CMAKE_BUILD_TYPE": "Release"}

[tool_requires]
catch2/*:ninja/[~1]
fmt/*:cmake/[~4.4]
fmt/*:ninja/[~1]
