[settings]
arch=x86_64
build_type=Release
compiler=clang
compiler.cppstd=26
compiler.libcxx=libc++
compiler.sanitizer=AddressUndefinedBehavior
compiler.version=23
os=Linux

[buildenv]
CXX=clang++

[conf]
!&:tools.build:cxxflags=["-D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_DEBUG", "-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=address,undefined"]
&:tools.build:cxxflags=["-D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_DEBUG", "-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=address,undefined", "-g", "-Wall", "-Werror", "-Wextra", "-Wno-error=reserved-module-identifier"]
&:tools.cmake.cmaketoolchain:extra_variables={"CMAKE_BUILD_TYPE": "Release", "CMAKE_CXX_STDLIB_MODULES_JSON": "/usr/lib/llvm-23/lib/libc++.modules.json"}

[tool_requires]
catch2/*:ninja/[~1]
fmt/*:cmake/[~4.4]
fmt/*:ninja/[~1]
