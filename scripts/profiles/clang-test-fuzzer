[settings]
arch=x86_64
build_type=Release
compiler=clang
compiler.cppstd=26
compiler.libcxx=libstdc++
compiler.sanitizer=AddressUndefinedBehaviourFuzzer
compiler.version=23
os=Linux

[buildenv]
CXX=clang++
FUZZER_CXX_FLAGS=-fsanitize=address,fuzzer,undefined

[conf]
!&:tools.build:cxxflags=["-D_FORTIFY_SOURCE=3", "-D_GLIBCXX_ASSERTIONS=1", "-fcontract-evaluation-semantic=enforce", "-fcontracts", "-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=address,fuzzer-no-link,undefined"]
&:tools.build:cxxflags=["-D_FORTIFY_SOURCE=3", "-D_GLIBCXX_ASSERTIONS=1", "-fcontract-evaluation-semantic=enforce", "-fcontracts", "-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=address,fuzzer-no-link,undefined", "-g", "-Wall", "-Werror", "-Wextra"]
&:tools.cmake.cmaketoolchain:extra_variables={"CMAKE_BUILD_TYPE": "Release", "ENABLE_FUZZER": "1"}

[tool_requires]
catch2/*:ninja/[~1]
fmt/*:cmake/[~4.4]
fmt/*:ninja/[~1]
