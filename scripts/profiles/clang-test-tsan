[settings]
arch=x86_64
build_type=Debug
compiler=clang
compiler.cppstd=26
compiler.libcxx=libc++
compiler.sanitizer=ThreadUndefinedBehavior
compiler.version=22
os=Linux

[buildenv]
CXX=clang++

[conf]
!&:tools.build:cxxflags=["-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=thread,undefined"]
&:tools.build:cxxflags=["-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=thread,undefined", "-g", "-Wall", "-Werror", "-Wextra", "-Wno-error=reserved-module-identifier"]
&:tools.cmake.cmaketoolchain:extra_variables={"CMAKE_BUILD_TYPE": "Debug", "CMAKE_CXX_STDLIB_MODULES_JSON": "/usr/lib/llvm-23/lib/libc++.modules.json"}

[tool_requires]
catch2/*:ninja/[~1]
fmt/*:cmake/[~4.4]
fmt/*:ninja/[~1]
