{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true,
            },
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/clean",
            "group": {
                "kind": "build",
            },
            "presentation": {
                "clear": true,
            },
        },
        {
            "label": "lint",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/lint",
            "group": {
                "kind": "test",
            },
            "presentation": {
                "clear": true,
            },
        },
        {
            "label": "test",
            "dependsOn": "build",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/test",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "clear": true,
            },
        },
    ]
}
